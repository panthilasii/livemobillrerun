# Copy to ``.env`` and fill in your VPS-specific values, then
# ``docker compose up -d`` will pick them up.

# Public domain that points at the VPS. Caddy obtains a Let's
# Encrypt cert for this on first request.
DOMAIN=admin.example.com

# Optional: pin the cookie-signing secret across deploys. If left
# empty, the server generates one and stores it in
# ``data/.session_secret`` — fine for a single-VPS install but
# means rebuilding the container resets it (= every admin re-logs).
# Set it explicitly when you have ≥ 2 VPS / blue-green deploys.
#
# Generate with::    openssl rand -hex 32
SESSION_SECRET=
