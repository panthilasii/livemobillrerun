<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:id="@+id/sv_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:colorBackground"
        android:fillViewport="true"
        android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/preview_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:background="#000000">

            <!-- Width/height set programmatically in MainActivity to
                 enforce 9:16 portrait, capped at ~45% screen height so
                 the controls below stay visible without scrolling. -->
            <ImageView
                android:id="@+id/iv_preview"
                android:layout_width="216dp"
                android:layout_height="384dp"
                android:contentDescription="@string/preview_desc"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_preview_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:padding="6dp"
                android:background="#80000000"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="@string/preview_idle" />

            <TextView
                android:id="@+id/tv_preview_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:padding="6dp"
                android:background="#80000000"
                android:textColor="#ffffff"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:text="@string/preview_source_memory" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_loopback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loopback_label" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Rotation picker. Replaces the old binary "show as portrait"
             toggle. The user can now dial in any of the 4 right-angle
             rotations plus optional horizontal/vertical mirroring,
             which is enough to invert any FFmpeg `rotation_filter` the
             PC streamer might be applying. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rotation_label"
                android:textStyle="bold" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Spinner
                android:id="@+id/sp_rotation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_mirror_h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mirror_h_label" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/cb_mirror_v"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mirror_v_label" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Kept for backwards compatibility with existing intent extras
             that flip this toggle. Hidden by default; the rotation
             spinner above replaces its UI role. -->
        <CheckBox
            android:id="@+id/cb_portrait"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/portrait_label"
            android:visibility="gone" />

        <EditText
            android:id="@+id/et_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_host"
            android:inputType="text"
            android:text="127.0.0.1" />

        <EditText
            android:id="@+id/et_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_port"
            android:inputType="number"
            android:text="8888" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_start" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/btn_stop" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_go_live"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_go_live" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/status_idle" />

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>
    </ScrollView>

    <!-- Fullscreen "Live" overlay. Visibility=gone unless user
         taps the Go Live button; covers the whole screen with a
         single ImageView so TikTok's MediaProjection sees nothing
         but the streamed video. -->
    <FrameLayout
        android:id="@+id/live_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_live"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/preview_desc"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tv_live_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="12dp"
            android:padding="6dp"
            android:background="#80000000"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="@string/live_hint" />
    </FrameLayout>
</FrameLayout>
