# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project-specific
vcam-pc/videos/*
!vcam-pc/videos/.gitkeep
vcam-pc/.cache/
vcam-pc/logs/
vcam-pc/tools/bin/
.tools/
.cache/
*.log
# Pulled TikTok APKs + LSPatch outputs (1+ GB, regeneratable)
.cache/lspatch/

# PyInstaller artefacts (recreated on every build)
vcam-pc/build/
vcam-pc/dist/
vcam-pc/*.spec

# Android
vcam-app/build/
vcam-app/.gradle/
vcam-app/local.properties
vcam-app/app/build/
*.apk
*.aab
*.keystore
!vcam-magisk/module/keystore.example
# Local-only APK rollback snapshots + apksigner artefacts.
# We keep the *current* signed APK in apk/ but ignore version-tagged
# backups (created by the release script) and the .idsig signature
# blocks that apksigner writes next to every signed APK.
apk/*.bak.*
apk/*.idsig

# Magisk module build artifacts
vcam-magisk/dist/
vcam-magisk/*.zip
vcam-magisk/src/zygisk/build/
vcam-magisk/src/zygisk/third_party/dobby/
vcam-magisk/src/zygisk/third_party/shadowhook/

# Secrets / credentials
.env
.env.*
!.env.example
*.pem
*.key
.auth_cache/

# NP Create — Ed25519 signing seed + issued-key audit log
# (admin only, NEVER commit — these contain customer PII + signing material)
.private_key
vcam-pc/.private_key
license_history.json
vcam-pc/license_history.json
# Legacy HMAC secret (kept ignored in case any old workspace still has one)
.license_secret
vcam-pc/.license_secret
# Customer activation files (per-user, machine-bound)
.npcreate/
.livestudio/

# NP Create — runtime state (regenerated every launch, contains
# device IDs / patch fingerprints / live session metadata that we
# do NOT want in version control)
#
# SQLite WAL/SHM journals (the admin dashboard's session DB).
# `*.sqlite3` covers the main DB; `-shm` / `-wal` are SQLite's
# write-ahead log siblings — committing them would cause merge
# pain on every dashboard run.
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.sqlite

# Encoded video preview cache. ffmpeg writes here on every encode;
# files are 5-50 MB each and entirely regeneratable from the
# customer's source clip plus the rotation/crop profile. Safe to
# delete at any time.
vcam-pc/cache/
vcam-pc/.encode_cache/
